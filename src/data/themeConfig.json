{
  "colors": {
    "primary": "pink-600",
    "primaryHover": "pink-700",
    "secondary": "purple-600",
    "accent": "pink-500",
    "text": {
      "primary": "gray-900",
      "secondary": "gray-600",
      "light": "gray-400",
      "white": "white"
    },
    "background": {
      "white": "white",
      "light": "gray-50",
      "lighter": "gray-100"
    },
    "border": "gray-200",
    "gradient": {
      "primary": "from-pink-500 to-purple-600",
      "primaryReverse": "from-pink-600 to-purple-500"
    }
  },
  "fonts": {
    "heading": {
      "size": {
        "xs": "text-xl",
        "sm": "text-2xl",
        "md": "text-3xl",
        "lg": "text-4xl",
        "xl": "text-5xl",
        "2xl": "text-6xl"
      },
      "weight": "font-extrabold",
      "lineHeight": "leading-tight"
    },
    "body": {
      "size": {
        "xs": "text-xs",
        "sm": "text-sm",
        "base": "text-base",
        "lg": "text-lg",
        "xl": "text-xl"
      },
      "weight": "font-medium",
      "lineHeight": "leading-relaxed"
    },
    "button": {
      "size": "text-sm",
      "weight": "font-semibold"
    }
  },
  "spacing": {
    "section": {
      "py": "py-12 sm:py-16 lg:py-20"
    },
    "container": {
      "maxWidth": "max-w-[1300px]",
      "padding": "px-4 sm:px-6 lg:px-8"
    }
  },
  "components": {
    "button": {
      "primary": "bg-pink-600 hover:bg-pink-700 text-white",
      "outline": "border-2 border-pink-600 text-pink-600 hover:bg-pink-50 hover:text-pink-700"
    },
    "card": {
      "border": "border-2 border-gray-200",
      "shadow": "shadow-sm hover:shadow-md",
      "rounded": "rounded-lg"
    }
  }
}
